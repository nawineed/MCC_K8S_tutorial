5. List NFS Mount Point
exportfs
#show
/mnt/nfs_share   10.200.120.0/23

6. Test mount NFS
mkdir /tmp
mount -t nfs yourIPAddress:/mnt/nfs_share /tmp

7. Verify NFS can mount to /tmp
df -h |grep :/mnt/nfs_share
